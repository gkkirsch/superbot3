#!/usr/bin/env node

const { program } = require('commander');
const path = require('path');

const SUPERBOT3_HOME = process.env.SUPERBOT3_HOME || path.join(require('os').homedir(), '.superbot3');

program
  .name('superbot3')
  .description('AI orchestration platform built on Claude Code')
  .version('0.1.0');

// ── init ────────────────────────────────────────────────────────────────────
program.command('init').description('Create ~/.superbot3/ skeleton')
  .action(() => require('../src/commands/init')(SUPERBOT3_HOME));

// ── start / stop ────────────────────────────────────────────────────────────
program.command('start').description('Boot broker + master + all active spaces')
  .action(() => require('../src/commands/start')(SUPERBOT3_HOME));

program.command('stop').description('Stop everything')
  .action(() => require('../src/commands/stop-all')(SUPERBOT3_HOME));

program.command('reload').description('Restart broker only — spaces stay alive')
  .action(() => require('../src/commands/reload')(SUPERBOT3_HOME));

program.command('update').description('Pull latest, install deps, rebuild dashboard')
  .action(() => require('../src/commands/update')());

// ── space ───────────────────────────────────────────────────────────────────
const space = program.command('space').description('Manage spaces');

space.command('create <name>')
  .description('Create a new space')
  .option('--code-dir <path>', 'Working directory for this space')
  .option('--model <model>', 'Claude model (opus, sonnet, haiku)')
  .option('--system-prompt <file>', 'Custom system prompt file')
  .option('--agent <name>', 'Agent definition to use')
  .action((name, opts) => require('../src/commands/space-create')(SUPERBOT3_HOME, name, opts));

space.command('list').description('List all spaces')
  .action(() => require('../src/commands/space-list')(SUPERBOT3_HOME));

space.command('status <name>').description('Show detailed space status')
  .action((name) => require('../src/commands/space-status')(SUPERBOT3_HOME, name));

space.command('start <name>').description('Start a space')
  .action((name) => {
    const { launchSpace } = require('../src/launchSpace');
    const ok = launchSpace(SUPERBOT3_HOME, name);
    if (ok) console.log(`Space "${name}" started.`);
    else { console.error(`Failed to start "${name}".`); process.exit(1); }
  });

space.command('stop <name>').description('Stop a space')
  .option('--force', 'Force stop')
  .action((name, opts) => require('../src/commands/stop')(SUPERBOT3_HOME, name, opts));

space.command('restart <name>').description('Restart a space')
  .action((name) => require('../src/commands/restart')(SUPERBOT3_HOME, name));

space.command('remove <name>').description('Remove a space and its directory')
  .action((name) => require('../src/commands/space-remove')(SUPERBOT3_HOME, name));

space.command('peek <name>').description('Show last 50 lines of space output')
  .action((name) => require('../src/commands/peek')(SUPERBOT3_HOME, name));

// ── worker ──────────────────────────────────────────────────────────────────
const worker = program.command('worker').description('Manage workers');

worker.command('spawn <space> <name> <prompt>')
  .description('Spawn a worker in a space')
  .option('--cwd <path>', 'Working directory')
  .option('--model <model>', 'Claude model')
  .option('--type <type>', 'Agent type (matches .claude/agents/<type>.md)')
  .option('--agent <name>', 'Agent definition')
  .option('--color <color>', 'Pane border color')
  .action((space, name, prompt, opts) => require('../src/commands/spawn-worker')(SUPERBOT3_HOME, space, name, prompt, opts));

worker.command('list [space]').description('List workers')
  .action((space) => require('../src/commands/workers')(SUPERBOT3_HOME, space));

worker.command('message <space> <worker> <text>').description('Message a worker')
  .action(async (space, workerName, text) => require('../src/commands/message-worker')(SUPERBOT3_HOME, space, workerName, text));

worker.command('kill <space> <name>').description('Kill a worker')
  .action(async (space, name) => require('../src/commands/kill-worker')(SUPERBOT3_HOME, space, name));

worker.command('restart <space> <name>').description('Restart a worker')
  .action(async (space, name) => require('../src/commands/restart-worker')(SUPERBOT3_HOME, space, name));

worker.command('interrupt <space> <name>').description('Interrupt a worker')
  .option('-m, --message <text>', 'Follow-up message')
  .action(async (space, name, opts) => require('../src/commands/interrupt-worker')(SUPERBOT3_HOME, space, name, opts));

worker.command('peek <space> <name>').description('Show last 50 lines of worker output')
  .action((space, name) => require('../src/commands/peek')(SUPERBOT3_HOME, space, name));

worker.command('hibernate <space> <name>')
  .description('Hibernate a worker (kill process, preserve session)')
  .action((space, name) => require('../src/commands/hibernate-worker')(SUPERBOT3_HOME, space, name));

worker.command('resume <space> <name> [prompt]')
  .description('Resume a hibernated worker')
  .action((space, name, prompt) => require('../src/commands/resume-worker')(SUPERBOT3_HOME, space, name, prompt));

worker.command('cleanup <space>')
  .description('Hibernate all alive workers in a space')
  .action((space) => require('../src/commands/cleanup-workers')(SUPERBOT3_HOME, space));

// ── message (shortcut) ─────────────────────────────────────────────────────
program.command('message <args...>')
  .description('Send message: message <space> "text" OR message "text" (to master)')
  .action((args) => {
    let spaceName = null, text;
    if (args.length === 1) { text = args[0]; }
    else { spaceName = args[0]; text = args.slice(1).join(' '); }
    require('../src/commands/message')(SUPERBOT3_HOME, spaceName, text);
  });

// ── peek (shortcut) ────────────────────────────────────────────────────────
program.command('peek <space> [worker]')
  .description('Peek at space or worker output')
  .action((space, workerName) => require('../src/commands/peek')(SUPERBOT3_HOME, space, workerName));

// ── self-management ─────────────────────────────────────────────────────────
const skill = program.command('skill').description('Manage space skills');
skill.command('create <space> <name>').option('--description <desc>').option('--body <body>')
  .action((s, n, o) => require('../src/commands/skill').create(SUPERBOT3_HOME, s, n, o));
skill.command('list <space>').action((s) => require('../src/commands/skill').list(SUPERBOT3_HOME, s));
skill.command('remove <space> <name>').action((s, n) => require('../src/commands/skill').remove(SUPERBOT3_HOME, s, n));

const agent = program.command('agent').description('Manage agent definitions');
agent.command('create <space> <name>').option('--description <desc>').option('--model <model>').option('--body <body>')
  .action((s, n, o) => require('../src/commands/agent').create(SUPERBOT3_HOME, s, n, o));
agent.command('list <space>').action((s) => require('../src/commands/agent').list(SUPERBOT3_HOME, s));
agent.command('show <space> <name>').action((s, n) => require('../src/commands/agent').show(SUPERBOT3_HOME, s, n));
agent.command('remove <space> <name>').action((s, n) => require('../src/commands/agent').remove(SUPERBOT3_HOME, s, n));

const settings = program.command('settings').description('Manage space settings');
settings.command('get <space> [key]').action((s, k) => require('../src/commands/settings').get(SUPERBOT3_HOME, s, k));
settings.command('set <space> <key> <value>').action((s, k, v) => require('../src/commands/settings').set(SUPERBOT3_HOME, s, k, v));
settings.command('unset <space> <key>').action((s, k) => require('../src/commands/settings').unset(SUPERBOT3_HOME, s, k));

const hook = program.command('hook').description('Manage space hooks');
hook.command('add <space> <event> <command>').action((s, e, c) => require('../src/commands/settings').hookAdd(SUPERBOT3_HOME, s, e, c));
hook.command('list <space>').action((s) => require('../src/commands/settings').hookList(SUPERBOT3_HOME, s));
hook.command('remove <space> <event> <index>').action((s, e, i) => require('../src/commands/settings').hookRemove(SUPERBOT3_HOME, s, e, i));

const mcp = program.command('mcp').description('Manage MCP servers');
mcp.command('add <space> <name> <command> [args...]').action((s, n, c, a) => require('../src/commands/settings').mcpAdd(SUPERBOT3_HOME, s, n, c, a));
mcp.command('list <space>').action((s) => require('../src/commands/settings').mcpList(SUPERBOT3_HOME, s));
mcp.command('remove <space> <name>').action((s, n) => require('../src/commands/settings').mcpRemove(SUPERBOT3_HOME, s, n));

program.command('permit <space> <rule>').description('Add a permission rule')
  .action((s, r) => require('../src/commands/settings').permitAdd(SUPERBOT3_HOME, s, r));

program.command('logs <space>').description('Tail space log')
  .action((s) => require('../src/commands/logs')(SUPERBOT3_HOME, s));

const schedule = program.command('schedule').description('Manage schedules');
schedule.command('add <space> <cron> <prompt>').option('--once')
  .action((s, c, p, o) => require('../src/commands/schedule').add(SUPERBOT3_HOME, s, c, p, o));
schedule.command('list <space>').action((s) => require('../src/commands/schedule').list(SUPERBOT3_HOME, s));
schedule.command('remove <space> <id>').action((s, i) => require('../src/commands/schedule').remove(SUPERBOT3_HOME, s, i));

// ── Legacy aliases (backwards compat) ───────────────────────────────────────
program.command('restart <space>', { hidden: true })
  .action((s) => require('../src/commands/restart')(SUPERBOT3_HOME, s));
program.command('spawn-worker <space> <name> <prompt>', { hidden: true })
  .option('--cwd <path>').option('--model <model>').option('--type <type>', 'Agent type').option('--color <color>')
  .action((s, n, p, o) => require('../src/commands/spawn-worker')(SUPERBOT3_HOME, s, n, p, o));
program.command('workers [space]', { hidden: true })
  .action((s) => require('../src/commands/workers')(SUPERBOT3_HOME, s));
program.command('kill-worker <space> <name>', { hidden: true })
  .action(async (s, n) => require('../src/commands/kill-worker')(SUPERBOT3_HOME, s, n));
program.command('restart-worker <space> <name>', { hidden: true })
  .action(async (s, n) => require('../src/commands/restart-worker')(SUPERBOT3_HOME, s, n));
program.command('message-worker <space> <worker> <text>', { hidden: true })
  .action(async (s, w, t) => require('../src/commands/message-worker')(SUPERBOT3_HOME, s, w, t));
program.command('interrupt <space> <worker>', { hidden: true })
  .option('-m, --message <text>')
  .action(async (s, w, o) => require('../src/commands/interrupt-worker')(SUPERBOT3_HOME, s, w, o));

program.command('hibernate-worker <space> <name>', { hidden: true })
  .action((s, n) => require('../src/commands/hibernate-worker')(SUPERBOT3_HOME, s, n));
program.command('resume-worker <space> <name> [prompt]', { hidden: true })
  .action((s, n, p) => require('../src/commands/resume-worker')(SUPERBOT3_HOME, s, n, p));
program.command('cleanup-workers <space>', { hidden: true })
  .action((s) => require('../src/commands/cleanup-workers')(SUPERBOT3_HOME, s));

program.parse();
